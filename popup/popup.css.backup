body {
  font-family: 'Fira Mono', 'Consolas', 'Menlo', monospace;
  margin: 0;
  padding: 0;
  width: 400px;
  background: #18181b;
  color: #f8f8f2;
}
.tabs {
  display: flex;
  align-items: center;
  background: #232336;
  border-bottom: 2px solid #00ffe7;
  margin-top: 18px;
  margin-bottom: 24px;
  padding-top: 8px;
  padding-bottom: 8px;
  gap: 8px;
}
.tab-action {
  background: transparent;
  color: #00ffe7;
  border: none;
  font-size: 1.5em;
  margin-right: 18px;
  margin-left: 4px;
  cursor: pointer;
  transition: color 0.2s, text-shadow 0.2s;
  outline: none;
  box-shadow: none;
  padding: 0 8px;
  border-radius: 50%;
}
.tab-action:hover {
  color: #fff;
  text-shadow: 0 0 8px #00ffe7;
  background: #232336;
}
.tablink {
  flex: 1;
  padding: 14px 0;
  border: none;
  cursor: pointer;
  background: #232336;
  color: #00ffe7;
  font-weight: bold;
  letter-spacing: 1px;
  transition: background 0.2s, color 0.2s;
  outline: none;
  font-size: 1.3em;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tablink i {
  font-size: 1.3em;
}
.tablink:hover, .tablink.active {
  background: #00ffe7;
  color: #18181b;
}
.tabcontent {
  display: none;
  padding: 32px 20px 24px 20px;
  background: #18181b;
  border-radius: 0 0 8px 8px;
  box-shadow: 0 2px 16px #00ffe733;
}
.tabcontent.active {
  display: block;
}
.input, select, textarea {
  width: 100%;
  margin: 18px 0 18px 0;
  padding: 14px;
  box-sizing: border-box;
  background: #232336;
  color: #00ffe7;
  border: 1.5px solid #00ffe7;
  border-radius: 4px;
  font-family: inherit;
  font-size: 16px;
}
.btn {
  padding: 14px 22px;
  margin: 18px 0 18px 0;
  background: #00ffe7;
  color: #18181b;
  border: none;
  border-radius: 4px;
  font-weight: bold;
  font-family: inherit;
  font-size: 18px;
  box-shadow: 0 0 8px #00ffe7cc;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, box-shadow 0.2s;
}
.btn:hover {
  background: #18181b;
  color: #00ffe7;
  box-shadow: 0 0 16px #00ffe7;
  border: 1.5px solid #00ffe7;
}
#openWindowBtn {
  position: absolute;
  top: 16px;
  left: 16px;
  background: transparent;
  color: #00ffe7;
  box-shadow: none;
  border: none;
  font-size: 18px;
  padding: 0 6px;
  z-index: 10;
}
#openWindowBtn:hover {
  color: #fff;
  text-shadow: 0 0 8px #00ffe7;
  background: transparent;
}
#closeWindowBtn {
  background: transparent;
  color: #ff007a;
  box-shadow: none;
  border: none;
  font-size: 18px;
  padding: 0 6px;
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 10;
}
#closeWindowBtn:hover {
  color: #fff;
  text-shadow: 0 0 8px #ff007a;
  background: transparent;
}
.status {
  color: #00ffe7;
  font-size: 16px;
  margin-top: 18px;
  font-family: inherit;
}
.result, .history-list {
  background: #232336;
  padding: 16px;
  border: 1.5px solid #00ffe7;
  font-size: 15px;
  margin-top: 18px;
  white-space: pre-wrap;
  border-radius: 4px;
  color: #f8f8f2;
  box-shadow: 0 0 8px #00ffe7cc;
}
