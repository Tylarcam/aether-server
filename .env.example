# Copy to .env and fill in your keys (never commit .env)

# Groq API key for server-side transcription
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Groq API key for browser-side transcription (Settings can override)
VITE_GROQ_API_KEY=

# Public URL for the deployed server — set this to your Railway URL after deploying
# Used by the extension to reach /api/extract-audio (YouTube audio download)
# SERVER_URL=https://your-app.railway.app     (set in Railway env vars)
# VITE_SERVER_URL=https://your-app.railway.app (set in .env before rebuilding the extension)
