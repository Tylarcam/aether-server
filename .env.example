# Copy to .env and fill in your keys (never commit .env)

# Groq API key for server-side transcription
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Groq API key for browser-side transcription (Settings can override)
VITE_GROQ_API_KEY=

# Optional: public URL for the deployed server (Railway sets this automatically)
# SERVER_URL=https://your-app.railway.app
