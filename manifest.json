{
  "manifest_version": 3,
  "name": "Aether",
  "version": "1.0",
  "description": "Transcribe any YouTube video or browser tab audio — free, no API key needed.",
  "permissions": [
    "activeTab",
    "storage",
    "tabCapture",
    "downloads"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ]
    }
  ],
  "host_permissions": [
    "https://*/*"
  ]
}