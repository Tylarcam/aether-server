{
  "manifest_version": 3,
  "name": "Aether Audio Transcriber",
  "version": "2.0.0",
  "description": "Premium audio transcription with real-time visualization",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabCapture",
    "downloads",
    "notifications",
    "offscreen",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/recordingIndicator.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
